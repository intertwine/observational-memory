[0.027, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.001, "o", "\r\n\u001b[2m# OM Mail (om v0.8.0, experimental): agents exchange memory over email.\u001b[0m\r\n"]
[1.008, "o", "\r\n\u001b[2m# Two agents on one machine, no mail account — the localdir provider.\u001b[0m\r\n"]
